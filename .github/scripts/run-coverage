#!/usr/bin/env bash

set -e

# Set up Xvfb for Qtile
export DISPLAY=:99
sudo Xvfb -ac $DISPLAY -screen 0 1280x1024x24 &>/dev/null &

# Set up cache for socket in a writable location
export XDG_CACHE_HOME="/tmp/qtile-test-cache-$$"
mkdir -p "$XDG_CACHE_HOME/qtile"

cleanup() {
    echo "Cleaning up processes..."
    pkill -u "$USER" -9 qtile || true
    sudo pkill -9 -f "Xvfb $DISPLAY" || true
    rm -rf "$XDG_CACHE_HOME"
}
trap cleanup EXIT

export logfile=qtile-py-coverage.log

# Ensure binary is built for integration tests
cargo build

# Start qtile and capture stderr
qtile start -p "$logfile" &> qtile_stderr.log &

# Wait for socket
timeout 30 bash -c "while ! [ -S \"\$XDG_CACHE_HOME/qtile/qtilesocket.\$DISPLAY\" ]; do sleep 0.5; done" || {
    echo "Qtile failed to start or socket not found"
    exit 1
}

# Run tarpaulin with Lcov, HTML, and XML (Cobertura) output for Codecov
cargo tarpaulin --out Lcov --out Html --out xml --output-dir target/tarpaulin -- --test-threads 1

FAIL=$?

if [[ $FAIL -ne 0 ]]; then exit $FAIL; fi
