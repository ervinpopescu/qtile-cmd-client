#!/bin/bash

set -ex

# Clean up any existing source to ensure a fresh build
rm -rf qtile-source

# Clone qtile
git clone https://github.com/qtile/qtile qtile-source
cd qtile-source

export UV_HTTP_TIMEOUT=300
# Use the provided python version or default to 3.12
PYTHON_VERSION="${1:-3.12}"

uv sync --python="$PYTHON_VERSION" --all-extras
# Build the CFFI backend for wayland
uv run ./libqtile/backend/wayland/cffi/build.py

# Install qtile as a tool with wayland support
uv tool install . --with ".[wayland]" --python "$PYTHON_VERSION" --force

# Add runner to video group if it exists
if getent group video >/dev/null; then
  sudo usermod -aG video runner || true
fi
